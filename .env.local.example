# ------------------------------------------------------------
# AWAAZ — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# (The real `.env.local` is gitignored. Never commit secrets.)
# ------------------------------------------------------------

# ----- OpenAI (required) -----
# Used by GPT-4o for: (1) extracting a structured profile from the user's
# Hindi/English speech and (2) matching to the right schemes.
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ----- Google Cloud Text-to-Speech (recommended primary TTS) -----
# Native Hindi (hi-IN-Neural2-A) and Indian English (en-IN-Neural2-A)
# voices that don't flip to English when reading numbers. Free tier is
# 1M characters / month for Neural2 voices — comfortably covers the demo.
#
# Setup (5 minutes):
#   1. https://console.cloud.google.com → sign in with any Gmail
#   2. Create a project (e.g. "awaaz-tts")
#   3. Search for "Cloud Text-to-Speech API" → click → Enable
#   4. Billing → link a card. NOT charged unless you exceed the free tier.
#   5. APIs & Services → Credentials → "+ Create Credentials" → API key
#   6. Restrict the key to "Cloud Text-to-Speech API" only
#   7. Paste below and restart `npm run dev`
#
# Option A: API key. When set, /api/tts uses Google and ElevenLabs becomes
# the fallback.
GOOGLE_TTS_API_KEY=

# Option B: service account JSON. Use this if API-key auth is blocked on your
# Google Cloud project. Paste the full JSON as one line. Service-account auth
# wins over GOOGLE_TTS_API_KEY when both are present.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional: path to a local service-account JSON file. Never commit that file.
GOOGLE_APPLICATION_CREDENTIALS=

# Optional voice overrides — defaults: hi-IN-Neural2-A, en-IN-Neural2-A
# Other Hindi voices: hi-IN-Neural2-B/C/D, hi-IN-Wavenet-A through E
# Browse: https://cloud.google.com/text-to-speech/docs/voices?language=hindi
GOOGLE_TTS_VOICE_HI=
GOOGLE_TTS_VOICE_EN=

# ----- ElevenLabs (fallback TTS) -----
# Used only if Google credentials are missing OR Google fails at runtime.
# Without either, the frontend falls back to the browser's built-in TTS.
#
# Free tier: 10,000 chars/month. Library voices (Kanika, Niraj, etc.) need
# Starter ($5/mo) — see voice-ID notes below.
#
# Get a key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ----- ElevenLabs Voice IDs (optional) -----
# Defaults to "Sarah" (free Default voice), which works for everyone on the
# free tier. Hindi pronunciation is good with multilingual_v2, but the
# accent is faintly non-Indian.
#
#   FREE TIER: only the 9 ElevenLabs Default voices work via the API.
#              Library / marketplace voices (Kanika, Niraj, etc.) return
#              HTTP 402 "paid_plan_required" until you upgrade to Starter
#              ($5/month, 30K characters).
#
# Once on Starter, paste any voice_id from https://elevenlabs.io/app/voice-library
# below. These are the best Hindi-native library voices for this app:
#   H6QPv2pQZDcGqLwDTIJQ — Kanika (relatable Hindi, female) ★ recommended
#   1qEiC6qsybMkmnNdVMbK — Monika Sogam (modulated Hindi, female)
#   v4ZRRmjvcrgAdi5qkWtZ — Parveen (clear Hindi, female)
#   zgqefOY5FPQ3bB7OZTVR — Niraj (Hindi narrator, male)
#   FmBhnvP58BK0vz65OOj7 — Viraj (energetic Hindi narrator, male)
#
# Free Default voice IDs (always available, paste here to swap):
#   EXAVITQu4vr4xnSDxMaL — Sarah (female, soft, default)
#   21m00Tcm4TlvDq8ikWAM — Rachel (female, calm)
#   pNInz6obpgDQGcFmaJgB — Adam (male, deep)
ELEVENLABS_VOICE_ID_HINDI=
ELEVENLABS_VOICE_ID_ENGLISH=

# ----- ElevenLabs model (optional) -----
# Defaults to `eleven_multilingual_v2` (best quality + supports Hindi).
# Override only if you need a different model (e.g. `eleven_turbo_v2_5` for
# lower latency, or `eleven_v3` if your account has access).
ELEVENLABS_MODEL_ID=

# ----- App -----
NEXT_PUBLIC_APP_NAME=Awaaz
